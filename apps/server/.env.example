BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your-database-token

# Shared secret used by the Cloudflare Email Worker.
INBOUND_EMAIL_SECRET=replace-with-at-least-32-characters

# The deployed Cloudflare Worker name used by Email Routing rules.
CF_EMAIL_WORKER_NAME=mailhog-email-ingest
