{
  "name": "mailhog",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/bun": "^1.3.14",
      "hono": "^4.12.27",
      "@orpc/server": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "better-auth": "1.6.23",
      "@orpc/client": "^1.14.6"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "dev:email-worker": "turbo run dev -F @mailhog/email-worker",
    "check:email-worker": "turbo run check -F @mailhog/email-worker",
    "deploy:email-worker": "turbo run deploy -F @mailhog/email-worker",
    "db:push": "turbo run db:push -F @mailhog/db",
    "db:studio": "turbo run db:studio -F @mailhog/db",
    "db:generate": "turbo run db:generate -F @mailhog/db",
    "db:migrate": "turbo run db:migrate -F @mailhog/db",
    "db:local": "turbo run db:local -F @mailhog/db",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry"
  },
  "dependencies": {
    "@mailhog/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mailhog/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "^22.13.14",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "vercel": "^54.18.6"
  },
  "packageManager": "bun@1.3.13"
}
